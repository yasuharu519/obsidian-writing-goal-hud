{
	"name": "writing-goal-hud",
	"version": "0.1.0",
	"description": "目標文字数までの進捗を画面右下にHUD表示するObsidianプラグイン",
	"main": "main.js",
	"packageManager": "pnpm@11.1.3",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"writing-goal",
		"word-count",
		"japanese"
	],
	"author": "yasuharu519",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	}
}
